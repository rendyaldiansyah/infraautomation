# Application
PORT=8080
NODE_ENV=production

# Database — RDS PostgreSQL (values loaded from SSM Parameter Store in production)
DB_HOST=your-rds-endpoint.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=lksdb
DB_USER=lksadmin
DB_PASSWORD=LKSSecure2026!

# AWS
AWS_REGION=us-east-1
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/lks-event-queue
DYNAMODB_TABLE=lks-sessions

# CORS — set to your ALB DNS name in production
CORS_ORIGIN=http://your-lks-alb-dns.us-east-1.elb.amazonaws.com

# Metrics server port for Prometheus scraping via VPC Peering
# Security Group lks-sg-ecs must allow inbound TCP 9100 from 10.1.0.0/16
METRICS_PORT=9100
